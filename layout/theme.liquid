<!doctype html>
<html lang="en">
  <head>
    {{ content_for_header }}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>

    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background-color: var(--color-background) !important;
        color: var(--color-text) !important;
        font-family: var(--font-body), var(--font-body-fallback) !important;
        font-size: var(--font-base-size);
        line-height: 1.5;
      }
      a { text-decoration: none; color: inherit; }
      h1,h2,h3,h4,h5,h6,p,label,div,span { color: var(--color-text); font-family: inherit; }
      .w-100{width:100%;}
      .bg-black{background:black}
      .white{color:white}
      .border-unset{border:unset}
      .outline-unset{outline:unset}

      .d-flex { display: flex; }
      .d-flex-imp { display: flex !important; }
      .row { flex-direction: row; }
      .column { flex-direction: column; }
      .wrap { flex-wrap: wrap; }
      .no-wrap { flex-wrap: nowrap; }
      .justify-space-between { justify-content: space-between; }
      .justify-left { justify-content: flex-start; }
      .justify-center { justify-content: center; }
      .justify-self-left{justify-self: left;}
      .justify-self-center{justify-self: center;}
      .justify-self-right{justify-self: right;}
      .capitalize{text-transform: capitalize;}
      .lowercase{text-transform: lowercase;}
      .uppercase{text-transform: uppercase;}
      .justify-right { justify-content: flex-end; }
      .align-center { align-items: center; }
      .align-left { align-items: flex-start; }
      .align-end { align-items: flex-end; }

      .width-100 { width: 100%; }
      .h-auto { height: auto; }
      .min-width-unset { min-width: unset !important; }
      .text-align-left{text-align:left;}

      .gap-1 { gap: 1rem; }
      .gap-2 { gap: 2rem; }
      .gap-3 { gap: 3rem; }
      .gap-4 { gap: 4rem; }
      .gap-5 { gap: 5rem; }

      .m-0 { margin: 0 !important; }
      .m-1 { margin: 1rem !important; }
      .m-2 { margin: 2rem !important; }
      .m-3 { margin: 3rem !important; }
      .mb-1 { margin-bottom: 1rem; }
      .mb-2 { margin-bottom: 2rem; }
      .mt-1 { margin-top: 1rem; }
      .ml-1 { margin-left: 1rem; }
      .mr-1 { margin-right: 1rem; }

      .p-0 { padding: 0 !important; }
      .p-1 { padding: 1rem !important; }
      .p-2 { padding: 2rem !important; }
      .p-3 { padding: 3rem !important; }
      .p-4 { padding: 4rem !important; }
      .p-5 { padding: 5rem !important; }
      .px-1 { padding-left: 1rem; padding-right: 1rem; }
      .px-2 { padding-left: 2rem; padding-right: 2rem; }
      .py-1 { padding-top: 1rem; padding-bottom: 1rem; }
      .py-1d5 { padding-top: 1.5rem; padding-bottom: 1.5rem; }
      .pr-1-imp{padding-right:1rem !important}
      .pr-0-imp{padding-right:0rem !important}
      .page-pa { padding: 1rem 3rem; }
      @media (max-width: 426px){
        .page-pa { padding: 1rem 1rem; !important }
      }

      .flex-1 { flex: 1; }
      .flex-2 { flex: 2; }
      .flex-3 { flex: 3; }

      .border { border: 1px solid var(--color-border); }
      .border-0 { border: none; }
      .rounded-sm { border-radius: var(--radius-sm); }
      .rounded-md { border-radius: var(--radius-md); }
      .rounded-lg { border-radius: var(--radius-lg); }
      .rounded-pill { border-radius: var(--radius-pill); }

      .text-xs { font-size: var(--font-size-xs); }
      .text-sm { font-size: var(--font-size-sm); }
      .text-md { font-size: var(--font-size-md); }
      .text-lg { font-size: var(--font-size-lg); }
      .text-xl { font-size: var(--font-size-xl); }
      .text-xxl { font-size: var(--font-size-xxl); }
      .text-center { text-align: center; }
      .text-left { text-align: left; }
      .text-right { text-align: right; }

      li { list-style: none; }
      svg { width: 2rem; height: 2rem; }

      .d-grid{display:grid;}
      .grid-template-col-2{grid-template-columns:repeat(2,2fr);}
      .order-1{order:1}
      .order-2{order:2}
      .order-3{order:3}


      .p-relative{position: relative;}
      .p-absolute{position: absolute;}
      .z-index-1{z-index:1}
      .bottom-0{bottom:0px}
      .bottom-8{bottom:8px}
      .left-12{left:12px}
      .bold{font-weight:bold;}
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-background: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-border: {{ settings.color_border }};

        --font-heading: {{ settings.font_heading.family | default: 'Helvetica' }};
        --font-body: {{ settings.font_body.family | default: 'Helvetica' }};
        --font-base-size: {{ settings.font_base_size | default: 17 }}px;

        --font-heading-fallback: {{ settings.font_heading.fallback_families | default: 'sans-serif' }};
        --font-body-fallback: {{ settings.font_body.fallback_families | default: 'sans-serif' }};

        --font-size-xs: calc(var(--font-base-size) * 0.75);
        --font-size-sm: calc(var(--font-base-size) * 0.875);
        --font-size-md: var(--font-base-size);
        --font-size-lg: calc(var(--font-base-size) * 1.25);
        --font-size-xl: calc(var(--font-base-size) * 1.5);
        --font-size-xxl: calc(var(--font-base-size) * 2);

        --container-width: {{ settings.container_width }}px;
        --container-padding: 20px;

        --space-1: 4px;
        --space-2: 8px;
        --space-3: 12px;
        --space-4: 16px;
        --space-5: 24px;
        --space-6: 32px;
        --space-7: 48px;
        --space-8: 64px;

        --radius-sm: 4px;
        --radius-md: {{ settings.button_radius }}px;
        --radius-lg: 16px;
        --radius-pill: 999px;
      }

      h1,h2,h3,h4,h5,h6 {
        font-family: var(--font-heading), var(--font-heading-fallback);
      }

    </style>
  </head>

  <body>
    {% section 'announcement' %}
    {% section 'header' %}
    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}

  </body>
</html>