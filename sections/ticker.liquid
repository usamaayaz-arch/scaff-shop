<div class="ticker ticker--{{ section.id }}">
  <div class="ticker__track">
    {% for i in (1..20) %}
      <div class="ticker__container">
        {% for block in section.blocks %}
          <div class="ticker__item" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img
                width="auto"
                height="auto"
                class="ticker__image"
                src="{{ block.settings.image | image_url }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
              >
            {% endif %}

            {% if block.settings.text != blank %}
              <div>{{ block.settings.text }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .ticker--{{ section.id }} {
    overflow: hidden;
    position: relative;
  }

  .ticker--{{ section.id }} .ticker__track {
    display: flex;
    width: max-content;
    animation: ticker-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
  }

  .ticker--{{ section.id }} .ticker__container {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: {{ section.settings.padding_y }}rem;
    padding-bottom: {{ section.settings.padding_y }}rem;
    flex-shrink: 0;
  }

  .ticker--{{ section.id }} .ticker__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: {{ section.settings.font_size }}rem;
    white-space: nowrap;
  }
  .ticker--{{ section.id }} .ticker__item:nth-child(1) {
  padding-left: 2rem;
}

  .ticker--{{ section.id }} .ticker__image {
    width: {{ section.settings.image_size }}rem;
    height: auto;
  }

  @keyframes ticker-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-45%); }
  }

  .ticker--{{ section.id }}:hover .ticker__track {
    animation-play-state: paused;
  }
</style>


{% schema %}
{
  "name": "Ticker",
  "settings": [
    {
      "type": "range",
      "id": "image_size",
      "label": "Image Size",
      "min": 1,
      "max": 20,
      "step": 0.2,
      "unit": "rem",
      "default": 1
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 1,
      "max": 20,
      "step": 0.2,
      "unit": "rem",
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Space Top/Bottom",
      "min": 1,
      "max": 10,
      "step": 0.2,
      "unit": "rem",
      "default": 1
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 20
    }
  ],
  "blocks": [
    {
      "name": "Ticker Item",
      "type": "ticker",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [{ "name": "Ticker" }]
}
{% endschema %}
