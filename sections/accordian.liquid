{{ 'accordian.css' | asset_url | stylesheet_tag }}

<style>
  .accordion-section-{{ section.id }}{
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .accordion-header {
    text-transform: {{ section.settings.text_transform }};
    background: {{ section.settings.header_bg }};
  }

  .accordion-item summary {
    list-style: none;
  }

  .accordion-item summary::-webkit-details-marker {
    display: none;
  }

  .accordion-content {
    background: {{ section.settings.header_bg }};
    padding: 15px;
  }

  .accordion-arrow {
    transition: transform 0.3s ease;
  }

  .accordion-item[open] .accordion-arrow svg {
    transform: rotate(180deg);
  }
</style>

<section class="accordion-section accordion-section-{{ section.id }}">

  {% if section.settings.section_heading != blank %}
    <div class="accordion-heading-wrapper">
      <h2>{{ section.settings.section_heading }}</h2>
      {% if section.settings.section_description != blank %}
        <p class="section-description">
          {{ section.settings.section_description }}
        </p>
      {% endif %}
    </div>
  {% endif %}

  <div class="accordion {% if section.settings.full_width == false %}page-width{% endif %} d-flex column gap-2">
    {% for block in section.blocks %}
      <details 
        class="accordion-item"
        {% if forloop.first and section.settings.first_open %}
          open
        {% endif %}
      >
        <summary class="accordion-header">
          {{ block.settings.title }}

          {% if section.settings.show_icon %}
            <span class="accordion-arrow d-flex justify-center align-center">
              {{ 'arrow-down-icon.svg' | inline_asset_content }}
            </span>
          {% endif %}
        </summary>

        <div class="accordion-content">
          {{ block.settings.content }}
        </div>
      </details>
    {% endfor %}
  </div>

</section>

{% unless section.settings.allow_multiple %}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const items = document.querySelectorAll(
      ".accordion-section-{{ section.id }} details"
    );

    items.forEach((item) => {
      item.addEventListener("toggle", function () {
        if (this.open) {
          items.forEach((el) => {
            if (el !== this) {
              el.removeAttribute("open");
            }
          });
        }
      });
    });
  });
</script>
{% endunless %}

{% schema %}
{
  "name": "Advanced Accordion",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Section Description"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Width container",
      "default": false
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "allow_multiple",
      "label": "Allow Multiple Open",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Open First Item By Default",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Icon",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Accordion Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Accordion content goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advanced Accordion",
      "blocks": [{ "type": "accordion_item" }]
    }
  ]
}
{% endschema %}